{
 "version": "2.0.0",
 "tasks": [
  {
   "label": "run C",
   "type": "shell",
   "command": "clang",
   "args": [
    "${fileDirname}/*.c",
    "-o",
    "${fileDirname}/${fileBasenameNoExtension}",
    "&&",
    "${fileDirname}/${fileBasenameNoExtension}"
   ],
   "group": {
    "kind": "build",
    "isDefault": true
   }
  }
 ]
}